<?xml version="1.0" encoding="utf-8"?>
<!--
╔══════════════════════════════════════════════════════════════════════╗
║               ViTour Design System — Color Palette                  ║
║               Inspired by Travenor Travel UI Kit                    ║
╠══════════════════════════════════════════════════════════════════════╣
║  HOW TO USE                                                         ║
║  • Always reference by semantic name (e.g. @color/vitour_primary)   ║
║  • NEVER hardcode hex values directly in layouts                     ║
║  • For gradients, use the gradient drawables in /drawable/          ║
║                                                                     ║
║  NAMING CONVENTION                                                  ║
║  vitour_<role>          → Material3 semantic roles                  ║
║  vitour_<role>_alpha_XX → same color with XX% opacity               ║
║  vitour_gradient_*      → gradient endpoint colors                  ║
╚══════════════════════════════════════════════════════════════════════╝
-->
<resources>

    <!-- ════════════════════════════════════════════════════════════════
         PRIMARY — Deep Ocean Blue → Vivid Coral gradient
         Travenor signature: rich blue primary, warm coral accent.
         ════════════════════════════════════════════════════════════════ -->

    <!-- Gradient start: deep midnight blue — luxury, trust, travel -->
    <color name="vitour_gradient_start">#0D1B4B</color>
    <!-- Gradient mid: vibrant electric blue — energy, wanderlust -->
    <color name="vitour_gradient_mid">#1A56E8</color>
    <!-- Gradient end: warm coral — warmth, adventure, excitement -->
    <color name="vitour_gradient_end">#FF6B6B</color>

    <!-- Solid primary — used for buttons, icons, active states -->
    <color name="vitour_primary">#1A56E8</color>
    <color name="vitour_primary_dark">#0D3BBF</color>
    <color name="vitour_primary_light">#5B8EFF</color>
    <color name="vitour_on_primary">#FFFFFF</color>
    <color name="vitour_primary_container">#D6E4FF</color>
    <color name="vitour_on_primary_container">#001260</color>
    <!-- 12% opacity primary — used for ripples, pressed states -->
    <color name="vitour_primary_alpha_12">#1F1A56E8</color>
    <!-- 20% opacity primary — used for chip backgrounds -->
    <color name="vitour_primary_alpha_20">#331A56E8</color>

    <!-- ════════════════════════════════════════════════════════════════
         SECONDARY — Coral / Sunset Orange
         Used for: CTAs, price tags, featured badges, highlights
         ════════════════════════════════════════════════════════════════ -->

    <color name="vitour_secondary">#FF6B6B</color>
    <color name="vitour_secondary_dark">#E84040</color>
    <color name="vitour_secondary_light">#FF9A9A</color>
    <color name="vitour_on_secondary">#FFFFFF</color>
    <color name="vitour_secondary_container">#FFE5E5</color>
    <color name="vitour_on_secondary_container">#5A0000</color>

    <!-- ════════════════════════════════════════════════════════════════
         TERTIARY — Golden Amber
         Used for: star ratings, "Popular" badges, highlights
         ════════════════════════════════════════════════════════════════ -->

    <color name="vitour_tertiary">#FFB830</color>
    <color name="vitour_tertiary_dark">#D48C00</color>
    <color name="vitour_on_tertiary">#FFFFFF</color>
    <color name="vitour_tertiary_container">#FFF3D6</color>
    <color name="vitour_on_tertiary_container">#3A2000</color>

    <!-- ════════════════════════════════════════════════════════════════
         SEMANTIC STATUSES
         Used for: booking status chips
         ════════════════════════════════════════════════════════════════ -->

    <!-- Success — confirmed bookings -->
    <color name="vitour_success">#00C48C</color>
    <color name="vitour_success_container">#D6FFF4</color>
    <color name="vitour_on_success">#FFFFFF</color>

    <!-- Warning — pending bookings -->
    <color name="vitour_warning">#FFB830</color>
    <color name="vitour_warning_container">#FFF3D6</color>

    <!-- Error — cancelled bookings, form validation -->
    <color name="vitour_error">#FF4759</color>
    <color name="vitour_error_dark">#CC1A2E</color>
    <color name="vitour_on_error">#FFFFFF</color>
    <color name="vitour_error_container">#FFE5E8</color>

    <!-- ════════════════════════════════════════════════════════════════
         NEUTRAL SURFACES — Light Mode
         Travenor uses very light off-white backgrounds (not pure white)
         and layered card surfaces with subtle shadows.
         ════════════════════════════════════════════════════════════════ -->

    <!-- App background — the base layer (off-white, not stark white) -->
    <color name="vitour_background">#F7F8FC</color>
    <color name="vitour_on_background">#0D1220</color>

    <!-- Surface (cards, sheets, bottom nav bg) -->
    <color name="vitour_surface">#FFFFFF</color>
    <color name="vitour_on_surface">#0D1220</color>

    <!-- Surface variant (chip backgrounds, input fill, dividers) -->
    <color name="vitour_surface_variant">#EFF1F8</color>
    <color name="vitour_on_surface_variant">#4B5068</color>

    <!-- Surface elevated — cards floating above background -->
    <color name="vitour_surface_elevated">#FFFFFF</color>

    <!-- Hero/card overlay — dark gradient on top of images -->
    <color name="vitour_image_scrim_start">#00000000</color>
    <color name="vitour_image_scrim_end">#CC000000</color>

    <!-- ════════════════════════════════════════════════════════════════
         TEXT COLORS
         ════════════════════════════════════════════════════════════════ -->

    <color name="vitour_text_primary">#0D1220</color>      <!-- headings -->
    <color name="vitour_text_secondary">#4B5068</color>    <!-- body, labels -->
    <color name="vitour_text_tertiary">#9498B0</color>     <!-- hints, placeholder -->
    <color name="vitour_text_on_image">#FFFFFF</color>     <!-- text over dark images -->
    <color name="vitour_text_link">#1A56E8</color>         <!-- hyperlinks -->

    <!-- ════════════════════════════════════════════════════════════════
         OUTLINES & DIVIDERS
         ════════════════════════════════════════════════════════════════ -->

    <color name="vitour_outline">#DDE1F0</color>
    <color name="vitour_outline_variant">#F0F2F9</color>
    <color name="vitour_divider">#ECEEF8</color>

    <!-- ════════════════════════════════════════════════════════════════
         SHADOW & SCRIM
         ════════════════════════════════════════════════════════════════ -->

    <!-- Card shadow color (used with elevation or custom shadows) -->
    <color name="vitour_shadow">#0F0D1B4B</color>          <!-- 6% midnight blue -->
    <color name="vitour_shadow_medium">#261A56E8</color>   <!-- 15% primary -->

    <!-- Bottom sheet / dialog scrim -->
    <color name="vitour_scrim">#80000000</color>           <!-- 50% black -->

    <!-- ════════════════════════════════════════════════════════════════
         BOTTOM NAVIGATION STATE COLORS
         ════════════════════════════════════════════════════════════════ -->

    <!-- Active tab icon/text -->
    <color name="vitour_nav_active">#1A56E8</color>
    <!-- Inactive tab icon/text -->
    <color name="vitour_nav_inactive">#9498B0</color>

    <!-- ════════════════════════════════════════════════════════════════
         CONVENIENCE ALIASES
         ════════════════════════════════════════════════════════════════ -->

    <color name="white">#FFFFFF</color>
    <color name="black">#000000</color>
    <color name="transparent">#00000000</color>

</resources>