<?xml version="1.0" encoding="utf-8"?>
<!--
╔══════════════════════════════════════════════════════════════════════╗
║          ViTour Design System — Typography & Component Styles        ║
╠══════════════════════════════════════════════════════════════════════╣
║  HOW TO USE                                                         ║
║  Apply styles to views:                                             ║
║    android:textAppearance="@style/TextAppearance.ViTour.Headline"   ║
║    style="@style/Widget.ViTour.Button.Primary"                      ║
║                                                                     ║
║  HIERARCHY                                                          ║
║  TextAppearance.ViTour.*   → text size, color, weight, tracking     ║
║  Widget.ViTour.*           → full component styles                  ║
║  Shape.ViTour.*            → ShapeAppearance for cards/buttons      ║
╚══════════════════════════════════════════════════════════════════════╝
-->
<resources>

    <!-- ════════════════════════════════════════════════════════════════
         SHAPE APPEARANCE STYLES
         Used by MaterialCardView, MaterialButton, TextInputLayout.
         Reference: app:shapeAppearance="@style/Shape.ViTour.Card"
         ════════════════════════════════════════════════════════════════ -->

    <!-- Standard tour card: 20dp corners (Travenor signature) -->
    <style name="Shape.ViTour.Card" parent="ShapeAppearance.MaterialComponents.MediumComponent">
        <item name="cornerSize">@dimen/radius_card</item>
    </style>

    <!-- Featured hero card: 24dp corners -->
    <style name="Shape.ViTour.Card.Featured" parent="ShapeAppearance.MaterialComponents.LargeComponent">
        <item name="cornerSize">@dimen/radius_card_featured</item>
    </style>

    <!-- Primary button: 14dp radius — modern, not quite pill -->
    <style name="Shape.ViTour.Button" parent="ShapeAppearance.MaterialComponents.SmallComponent">
        <item name="cornerSize">@dimen/radius_button</item>
    </style>

    <!-- Pill button: fully rounded (search bar, filter chips) -->
    <style name="Shape.ViTour.Button.Pill" parent="ShapeAppearance.MaterialComponents.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <!-- Input field: 12dp corners -->
    <style name="Shape.ViTour.Input" parent="ShapeAppearance.MaterialComponents.SmallComponent">
        <item name="cornerSize">@dimen/radius_input</item>
    </style>

    <!-- Chip: pill shaped -->
    <style name="Shape.ViTour.Chip" parent="ShapeAppearance.MaterialComponents.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <!-- Bottom sheet: only top corners rounded -->
    <style name="Shape.ViTour.BottomSheet" parent="ShapeAppearance.MaterialComponents.LargeComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopRight">@dimen/radius_bottom_sheet</item>
        <item name="cornerSizeTopLeft">@dimen/radius_bottom_sheet</item>
        <item name="cornerSizeBottomRight">0dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
    </style>


    <!-- ════════════════════════════════════════════════════════════════
         TEXT APPEARANCE — Typography Scale
         Based on Material3 type scale with Travenor customizations.

         Font: Sans-serif (system default, clean and legible)
         Override with a custom font by setting android:fontFamily
         on the root theme or individual styles below.
         ════════════════════════════════════════════════════════════════ -->

    <!-- DISPLAY — Large hero text (e.g. "Discover the World") -->
    <style name="TextAppearance.ViTour.Display" parent="TextAppearance.MaterialComponents.Headline3">
        <item name="android:textSize">@dimen/text_display</item>
        <item name="android:textColor">@color/vitour_text_primary</item>
        <item name="android:fontFamily">sans-serif-bold</item>
        <item name="android:letterSpacing">-0.02</item>
        <item name="android:lineSpacingMultiplier">1.1</item>
    </style>

    <!-- HEADLINE LARGE — Screen titles (e.g. "My Bookings") -->
    <style name="TextAppearance.ViTour.Headline.Large" parent="TextAppearance.MaterialComponents.Headline4">
        <item name="android:textSize">@dimen/text_headline_lg</item>
        <item name="android:textColor">@color/vitour_text_primary</item>
        <item name="android:fontFamily">sans-serif-bold</item>
        <item name="android:letterSpacing">-0.01</item>
    </style>

    <!-- HEADLINE MEDIUM — Section titles (e.g. "Featured Destinations") -->
    <style name="TextAppearance.ViTour.Headline.Medium" parent="TextAppearance.MaterialComponents.Headline5">
        <item name="android:textSize">@dimen/text_headline_md</item>
        <item name="android:textColor">@color/vitour_text_primary</item>
        <item name="android:fontFamily">sans-serif-bold</item>
    </style>

    <!-- HEADLINE SMALL — Card titles, dialog titles -->
    <style name="TextAppearance.ViTour.Headline.Small" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textSize">@dimen/text_headline_sm</item>
        <item name="android:textColor">@color/vitour_text_primary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <!-- TITLE LARGE — Tour card name, list item title -->
    <style name="TextAppearance.ViTour.Title.Large" parent="TextAppearance.MaterialComponents.Subtitle1">
        <item name="android:textSize">@dimen/text_title_lg</item>
        <item name="android:textColor">@color/vitour_text_primary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <!-- TITLE MEDIUM — Emphasized body, button labels -->
    <style name="TextAppearance.ViTour.Title.Medium" parent="TextAppearance.MaterialComponents.Subtitle2">
        <item name="android:textSize">@dimen/text_title_md</item>
        <item name="android:textColor">@color/vitour_text_primary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <!-- TITLE SMALL — Small labels, metadata labels -->
    <style name="TextAppearance.ViTour.Title.Small" parent="TextAppearance.MaterialComponents.Body2">
        <item name="android:textSize">@dimen/text_title_sm</item>
        <item name="android:textColor">@color/vitour_text_secondary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <!-- BODY LARGE — Primary reading body text -->
    <style name="TextAppearance.ViTour.Body.Large" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textSize">@dimen/text_body_lg</item>
        <item name="android:textColor">@color/vitour_text_secondary</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:lineSpacingMultiplier">1.5</item>
    </style>

    <!-- BODY MEDIUM — Secondary body text, descriptions -->
    <style name="TextAppearance.ViTour.Body.Medium" parent="TextAppearance.MaterialComponents.Body2">
        <item name="android:textSize">@dimen/text_body_md</item>
        <item name="android:textColor">@color/vitour_text_secondary</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:lineSpacingMultiplier">1.4</item>
    </style>

    <!-- BODY SMALL — Captions, timestamps, metadata -->
    <style name="TextAppearance.ViTour.Body.Small" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textSize">@dimen/text_body_sm</item>
        <item name="android:textColor">@color/vitour_text_tertiary</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <!-- LABEL — Chip text, tags, status badges -->
    <style name="TextAppearance.ViTour.Label" parent="TextAppearance.MaterialComponents.Button">
        <item name="android:textSize">@dimen/text_label</item>
        <item name="android:textColor">@color/vitour_text_tertiary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <!-- OVERLINE — ALL CAPS section headers (e.g. "POPULAR TOURS") -->
    <style name="TextAppearance.ViTour.Overline" parent="TextAppearance.MaterialComponents.Overline">
        <item name="android:textSize">@dimen/text_overline</item>
        <item name="android:textColor">@color/vitour_text_tertiary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.15</item>
    </style>

    <!-- TEXT ON IMAGE — White text rendered over dark image overlays -->
    <style name="TextAppearance.ViTour.OnImage" parent="TextAppearance.ViTour.Title.Large">
        <item name="android:textColor">@color/vitour_text_on_image</item>
        <item name="android:shadowColor">#66000000</item>
        <item name="android:shadowDx">0</item>
        <item name="android:shadowDy">1</item>
        <item name="android:shadowRadius">4</item>
    </style>

    <!-- PRICE — Formatted price display (e.g. "$1,299") -->
    <style name="TextAppearance.ViTour.Price" parent="TextAppearance.ViTour.Title.Large">
        <item name="android:textColor">@color/vitour_primary</item>
        <item name="android:fontFamily">sans-serif-bold</item>
        <item name="android:textSize">@dimen/text_title_lg</item>
    </style>

    <!-- RATING — Star rating number -->
    <style name="TextAppearance.ViTour.Rating" parent="TextAppearance.ViTour.Label">
        <item name="android:textColor">@color/vitour_text_primary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>


    <!-- ════════════════════════════════════════════════════════════════
         WIDGET STYLES — MaterialCardView
         ════════════════════════════════════════════════════════════════ -->

    <!-- Standard tour card -->
    <style name="Widget.ViTour.Card" parent="Widget.MaterialComponents.CardView">
        <item name="shapeAppearance">@style/Shape.ViTour.Card</item>
        <item name="cardElevation">@dimen/elevation_card</item>
        <item name="cardBackgroundColor">@color/vitour_surface</item>
        <item name="strokeWidth">@dimen/stroke_thin</item>
        <item name="strokeColor">@color/vitour_outline_variant</item>
        <item name="android:layout_marginBottom">@dimen/spacing_card_gap</item>
    </style>

    <!-- Featured card (larger radius, no stroke, stronger shadow) -->
    <style name="Widget.ViTour.Card.Featured" parent="Widget.MaterialComponents.CardView">
        <item name="shapeAppearance">@style/Shape.ViTour.Card.Featured</item>
        <item name="cardElevation">@dimen/elevation_card_raised</item>
        <item name="cardBackgroundColor">@color/vitour_surface</item>
        <item name="strokeWidth">0dp</item>
    </style>


    <!-- ════════════════════════════════════════════════════════════════
         WIDGET STYLES — MaterialButton
         ════════════════════════════════════════════════════════════════ -->

    <!-- Primary filled button (Login, Book Now, etc.) -->
    <style name="Widget.ViTour.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="shapeAppearance">@style/Shape.ViTour.Button</item>
        <item name="android:minHeight">@dimen/size_button_height</item>
        <item name="android:textAppearance">@style/TextAppearance.ViTour.Title.Medium</item>
        <item name="android:textColor">@color/vitour_on_primary</item>
        <item name="backgroundTint">@color/vitour_primary</item>
        <item name="android:letterSpacing">0</item>
    </style>

    <!-- Secondary outlined button -->
    <style name="Widget.ViTour.Button.Secondary" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="shapeAppearance">@style/Shape.ViTour.Button</item>
        <item name="android:minHeight">@dimen/size_button_height</item>
        <item name="android:textAppearance">@style/TextAppearance.ViTour.Title.Medium</item>
        <item name="android:textColor">@color/vitour_primary</item>
        <item name="strokeColor">@color/vitour_primary</item>
        <item name="strokeWidth">@dimen/stroke_thin</item>
        <item name="android:letterSpacing">0</item>
    </style>

    <!-- Danger/Logout outlined button (red outline) -->
    <style name="Widget.ViTour.Button.Danger" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="shapeAppearance">@style/Shape.ViTour.Button</item>
        <item name="android:minHeight">@dimen/size_button_height</item>
        <item name="android:textColor">@color/vitour_error</item>
        <item name="strokeColor">@color/vitour_error</item>
        <item name="strokeWidth">@dimen/stroke_thin</item>
        <item name="android:letterSpacing">0</item>
    </style>

    <!-- Text/link button (no background) -->
    <style name="Widget.ViTour.Button.Text" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">@color/vitour_primary</item>
        <item name="android:textAppearance">@style/TextAppearance.ViTour.Title.Small</item>
        <item name="android:letterSpacing">0</item>
    </style>


    <!-- ════════════════════════════════════════════════════════════════
         WIDGET STYLES — TextInputLayout
         ════════════════════════════════════════════════════════════════ -->

    <!-- Standard outlined input (Login, Register, Search forms) -->
    <style name="Widget.ViTour.TextInput" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="shapeAppearance">@style/Shape.ViTour.Input</item>
        <item name="boxStrokeColor">@color/vitour_outline</item>
        <item name="boxStrokeWidth">@dimen/stroke_thin</item>
        <item name="boxStrokeWidthFocused">@dimen/stroke_medium</item>
        <item name="hintTextColor">@color/vitour_text_tertiary</item>
        <item name="android:textColorHint">@color/vitour_text_tertiary</item>
        <item name="boxBackgroundColor">@color/vitour_surface</item>
    </style>

    <!-- Filled input variant (for search bars embedded in surfaces) -->
    <style name="Widget.ViTour.TextInput.Filled" parent="Widget.MaterialComponents.TextInputLayout.FilledBox">
        <item name="shapeAppearance">@style/Shape.ViTour.Input</item>
        <item name="boxBackgroundColor">@color/vitour_surface_variant</item>
        <item name="hintTextColor">@color/vitour_text_tertiary</item>
        <item name="android:textColorHint">@color/vitour_text_tertiary</item>
    </style>


    <!-- ════════════════════════════════════════════════════════════════
         WIDGET STYLES — Chip
         ════════════════════════════════════════════════════════════════ -->

    <!-- Filter chip (e.g. category filters in Explore/Search) -->
    <style name="Widget.ViTour.Chip.Filter" parent="Widget.MaterialComponents.Chip.Filter">
        <item name="shapeAppearance">@style/Shape.ViTour.Chip</item>
        <item name="android:textAppearance">@style/TextAppearance.ViTour.Label</item>
        <item name="chipBackgroundColor">@color/vitour_surface_variant</item>
        <item name="chipStrokeColor">@color/vitour_outline</item>
        <item name="chipStrokeWidth">@dimen/stroke_thin</item>
        <item name="checkedIconVisible">false</item>
    </style>

    <!-- Status chip (Confirmed / Pending / Cancelled) -->
    <style name="Widget.ViTour.Chip.Status" parent="Widget.MaterialComponents.Chip.Entry">
        <item name="shapeAppearance">@style/Shape.ViTour.Chip</item>
        <item name="android:textAppearance">@style/TextAppearance.ViTour.Label</item>
        <item name="chipStartPadding">@dimen/spacing_chip_horizontal</item>
        <item name="chipEndPadding">@dimen/spacing_chip_horizontal</item>
        <item name="chipMinHeight">@dimen/size_button_height_sm</item>
    </style>

</resources>
