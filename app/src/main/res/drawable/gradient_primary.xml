<?xml version="1.0" encoding="utf-8"?>
<!--
    gradient_primary.xml
    ─────────────────────────────────────────────────────────────────
    Travenor signature: deep blue → coral diagonal gradient.
    Use on: Login hero area, Featured card background, hero banners.

    Usage:
      android:background="@drawable/gradient_primary"
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:startColor="@color/vitour_gradient_start"
        android:centerColor="@color/vitour_gradient_mid"
        android:endColor="@color/vitour_gradient_end"
        android:angle="135"
        android:type="linear" />
</shape>
