<?xml version="1.0" encoding="utf-8"?>
<!--
    bg_card_rounded.xml
    ─────────────────────────────────────────────────────────────────
    White rounded-corner card background (20dp corners).
    Use this on ConstraintLayout or LinearLayout when you need a
    rounded card WITHOUT MaterialCardView (e.g. inside ViewPager).

    Usage:
      android:background="@drawable/bg_card_rounded"
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/vitour_surface" />
    <corners android:radius="@dimen/radius_card" />
    <stroke
        android:width="@dimen/stroke_thin"
        android:color="@color/vitour_outline_variant" />
</shape>
