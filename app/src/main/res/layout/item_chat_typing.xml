<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingTop="8dp"
    android:paddingBottom="8dp">

    <ImageView
        android:id="@+id/imageAssistantAvatarTyping"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@drawable/ic_ai_assistant"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:contentDescription="AI Avatar Typing" />

    <!-- We would typically put a Lottie animation here for typing dots, 
         using a generic ProgressBar for the placeholder -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:background="@drawable/bg_chat_bubble_assistant"
        android:padding="12dp"
        app:layout_constraintStart_toEndOf="@id/imageAssistantAvatarTyping"
        app:layout_constraintTop_toTopOf="parent">

        <ProgressBar
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:indeterminate="true" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
